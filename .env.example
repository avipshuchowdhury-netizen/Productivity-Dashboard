# Firebase Web app config. These values come from Firebase Console > Project settings > Your apps.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Client-side access policy. Keep the domain locked to Varahe.
VITE_ALLOWED_AUTH_DOMAIN=varaheanalytics.com

# Optional extra client-side email allowlist inside the domain.
# Example: VITE_ALLOWED_AUTH_EMAILS=admin@example.com,ops@example.com
VITE_ALLOWED_AUTH_EMAILS=

# Client-side role hint for the entry management UI.
VITE_ENTRY_MANAGER_EMAILS=avipshu.chowdhury@varaheanalytics.com

# Secure API enforcement. Production enforces auth even if this is false.
FIREBASE_AUTH_ENFORCED=true
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Server-side access policy. This is the real enforcement layer.
FIREBASE_ALLOWED_DOMAIN=varaheanalytics.com

# Optional extra server-side email allowlist inside the domain.
# Example: FIREBASE_ALLOWED_EMAILS=admin@example.com,ops@example.com
FIREBASE_ALLOWED_EMAILS=

# Server-side editor/archive/delete role.
FIREBASE_ENTRY_MANAGER_EMAILS=avipshu.chowdhury@varaheanalytics.com

# Automated Meta + YouTube fetching. The manager UI sends an exact date range;
# SOCIAL_SYNC_LOOKBACK_DAYS is only the fallback for cron/default syncs.
# Keep tokens server-side only. Never expose these as VITE_* variables.
SOCIAL_SYNC_LOOKBACK_DAYS=7
SOCIAL_SYNC_MAX_ITEMS_PER_ACCOUNT=25
SOCIAL_SYNC_CRON_SECRET=
META_GRAPH_API_VERSION=v23.0

# Optional shared fallbacks. Per-account env names in SOCIAL_SYNC_ACCOUNTS are preferred.
META_PAGE_ACCESS_TOKEN=
YOUTUBE_API_KEY=
YOUTUBE_OAUTH_CLIENT_ID=
YOUTUBE_OAUTH_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=

# One-line JSON array. Replace ids, handles, states, authors, and env var names with real onboarded pages.
# Example:
# SOCIAL_SYNC_ACCOUNTS=[{"id":"samarth-national","name":"SAMARTH National Desk","author":"SAMARTH Desk","state":"National","facebookUrl":"https://facebook.com/samarthnational","instagramUrl":"https://instagram.com/samarthnational","youtubeUrl":"https://youtube.com/@samarthnational","facebook":{"pageId":"FACEBOOK_PAGE_ID","pageAccessTokenEnv":"META_PAGE_ACCESS_TOKEN"},"instagram":{"igUserId":"INSTAGRAM_BUSINESS_ACCOUNT_ID","accessTokenEnv":"META_PAGE_ACCESS_TOKEN"},"youtube":{"channelId":"YOUTUBE_CHANNEL_ID","apiKeyEnv":"YOUTUBE_API_KEY","refreshTokenEnv":"YOUTUBE_REFRESH_TOKEN","clientIdEnv":"YOUTUBE_OAUTH_CLIENT_ID","clientSecretEnv":"YOUTUBE_OAUTH_CLIENT_SECRET"}}]
SOCIAL_SYNC_ACCOUNTS=[]
