# Firebase Web app config. These values come from Firebase Console > Project settings > Your apps.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Client-side access policy. Keep the domain locked to Varahe.
VITE_ALLOWED_AUTH_DOMAIN=varaheanalytics.com

# Optional extra client-side email allowlist inside the domain.
# Example: VITE_ALLOWED_AUTH_EMAILS=admin@example.com,ops@example.com
VITE_ALLOWED_AUTH_EMAILS=

# Client-side role hint for the entry management UI.
VITE_ENTRY_MANAGER_EMAILS=avipshu.chowdhury@varaheanalytics.com

# Optional setup-only signup tab. Keep false/blank for single-admin production login.
VITE_ENABLE_ACCOUNT_CREATION=false

# Secure API enforcement. Production enforces auth even if this is false.
FIREBASE_AUTH_ENFORCED=true
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Server-side access policy. This is the real enforcement layer.
FIREBASE_ALLOWED_DOMAIN=varaheanalytics.com

# Optional extra server-side email allowlist inside the domain.
# Example: FIREBASE_ALLOWED_EMAILS=admin@example.com,ops@example.com
FIREBASE_ALLOWED_EMAILS=

# Server-side editor/archive/delete role.
FIREBASE_ENTRY_MANAGER_EMAILS=avipshu.chowdhury@varaheanalytics.com
